# SSH Key Schema Extensions for Samba AD DC
# Adds support for storing SSH public keys in AD user objects.
# References:
#   https://wiki.samba.org/index.php/Samba_AD_schema_extensions
#   OpenSSH LPK (LDAP Public Key) schema

# Add sshPublicKey attribute
dn: CN=sshPublicKey,CN=Schema,CN=Configuration,{{ samba_schema_base_dn }}
changetype: add
objectClass: top
objectClass: attributeSchema
attributeID: 1.3.6.1.4.1.24552.500.1.1.1.13
cn: sshPublicKey
name: sshPublicKey
lDAPDisplayName: sshPublicKey
description: OpenSSH Public key for user
attributeSyntax: 2.5.5.10
oMSyntax: 4
isSingleValued: FALSE
searchFlags: 8
adminDisplayName: SSH Public Key
adminDescription: OpenSSH Public key(s) for the user
showInAdvancedViewOnly: FALSE

-
dn:
changetype: modify
add: schemaUpdateNow
schemaUpdateNow: 1
-

# Add ldapPublicKey auxiliary class
dn: CN=ldapPublicKey,CN=Schema,CN=Configuration,{{ samba_schema_base_dn }}
changetype: add
objectClass: top
objectClass: classSchema
governsID: 1.3.6.1.4.1.24552.500.1.1.2.0
cn: ldapPublicKey
name: ldapPublicKey
description: OpenSSH LPK objectclass for storing SSH keys
lDAPDisplayName: ldapPublicKey
subClassOf: top
objectClassCategory: 3
defaultObjectCategory: CN=ldapPublicKey,CN=Schema,CN=Configuration,{{ samba_schema_base_dn }}
mayContain: sshPublicKey
adminDisplayName: LDAP Public Key
adminDescription: Auxiliary class for SSH public keys
showInAdvancedViewOnly: FALSE

-
dn:
changetype: modify
add: schemaUpdateNow
schemaUpdateNow: 1
-

# Add ldapPublicKey as auxiliary class to User
dn: CN=User,CN=Schema,CN=Configuration,{{ samba_schema_base_dn }}
changetype: modify
add: auxiliaryClass
auxiliaryClass: ldapPublicKey
-

dn:
changetype: modify
add: schemaUpdateNow
schemaUpdateNow: 1
-
