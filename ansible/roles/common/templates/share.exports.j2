{# share.exports.j2 - Per-share NFSv4 export entry for /etc/exports.d/. #}
{# Shared between the samba-dc role (colocated NFS) and the nfs-server role #}
{# (dedicated storage host). #}
{# #}
{# Each share gets its own .exports file for independent management. #}
{# NFSv4 clients use the full server path when no pseudo-root is defined. #}
{# #}
{# Export options: #}
{#   rw              Read-write access #}
{#   sec=krb5p       Kerberos authentication + integrity + privacy (encryption) #}
{#   sync            Commit writes to disk before replying (safe but slower) #}
{#   no_subtree_check Skip subtree checking (recommended for single-directory exports) #}
{# #}
{# Callers pass `samba_share_base` and `samba_nfs_sec` via task-level vars:. #}
{{ item.path | default(samba_share_base ~ '/' ~ item.name) }} *(rw,sec={{ samba_nfs_sec }},sync,no_subtree_check)
