[libdefaults]
    default_realm = {{ samba_realm }}
    dns_lookup_realm = false
    dns_lookup_kdc = true
    ticket_lifetime = 24h
    renew_lifetime = 7d
    forwardable = true
    rdns = false

[realms]
{{ samba_realm }} = {
    kdc = {{ inventory_hostname }}
    admin_server = {{ inventory_hostname }}
}

[domain_realm]
    .{{ samba_realm | lower }} = {{ samba_realm }}
    {{ samba_realm | lower }} = {{ samba_realm }}
