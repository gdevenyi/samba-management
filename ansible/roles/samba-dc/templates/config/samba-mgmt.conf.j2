# samba-mgmt.conf - Site-specific configuration for the Samba AD DC management scripts.
#
# Format: KEY=VALUE (no quotes required unless the value contains spaces).
# Lines starting with # are comments.  This file is read by lib/config.sh
# and the values are exported as environment variables.
#
# SECURITY: Do NOT store passwords here.  All admin/user passwords are
# prompted interactively by the management scripts.
#
# --- Domain identity ---
REALM={{ samba_realm }}
DOMAIN={{ samba_domain }}
NETBIOS={{ samba_netbios }}

# --- Domain controller ---
DC_HOSTNAME={{ ansible_hostname }}

# --- Samba paths ---
SAMBA_CONF=/etc/samba/smb.conf
SHARE_BASE={{ samba_share_base }}
HOME_BASE={{ samba_home_base }}

# --- User defaults ---
DEFAULT_SHELL=/bin/bash
DEFAULT_GROUP="Domain Users"

# --- Logging ---
LOG_FILE=/var/log/samba-management.log

# --- Linux client automount ---
AUTOMOUNT_BASE={{ samba_autofs_shares_mount }}
NFS_SEC={{ samba_nfs_sec }}
NFS_SERVER={{ samba_nfs_server if samba_nfs_server else ansible_fqdn }}
# Host that serves user home directories over NFS.  When this is not the
# DC, samba-user.sh SSHes here as root to manage {{ samba_home_base }}/<user>.
NFS_HOMES_SERVER={{ samba_nfs_homes_server if samba_nfs_homes_server else (samba_nfs_server if samba_nfs_server else ansible_fqdn) }}

# DNS forwarder, NTP servers, and TLS settings are configured directly by the
# samba-dc role (samba_dns_forwarder / samba_ntp_servers / samba_tls_enabled
# in defaults/main.yml) -- the bin/* scripts don't consume them, so they're
# omitted from this generated file.
