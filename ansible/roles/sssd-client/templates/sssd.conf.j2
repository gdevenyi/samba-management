{# sssd.conf.j2 - SSSD configuration for AD authentication on Linux clients. #}
{# #}
{# Deployed with mode 0600 because SSSD refuses to start if this file #}
{# is readable by non-root users (it may contain sensitive parameters). #}

[sssd]
domains = {{ sssd_domain }}
{# No `services` line: on systemd hosts SSSD's responders are socket-activated
   (sssd-<service>.socket units), which is the upstream-recommended model and
   the default on Ubuntu 24.04+.  Listing a responder here *and* having its
   socket enabled trips sssd_check_socket_activated_responders (exit-code 17)
   at boot, so every conflicting socket fails to listen.  Which responder
   sockets to enable is asserted by the sssd-client role (services.yml); the
   per-responder config below (sudo_provider / autofs_provider / ssh keys)
   is read by the responders regardless of how they were started. #}

[domain/{{ sssd_domain }}]
default_shell = {{ sssd_default_shell }}
{# Store credentials for offline authentication when the DC is unreachable #}
krb5_store_password_if_offline = True
cache_credentials = {{ 'True' if sssd_cache_credentials else 'False' }}
{# realmd_tags are set by realm join; keeping them prevents realm from #}
{# overwriting our config on subsequent realm operations #}
realmd_tags = manages-system joined-with-adcli
id_provider = ad
fallback_homedir = {{ sssd_effective_fallback_homedir }}
ad_domain = {{ sssd_domain }}
use_fully_qualified_names = {{ 'True' if sssd_use_fully_qualified_names else 'False' }}
access_provider = {{ sssd_access_provider }}
{# sssd-ldap.5 recommends disabling referral chasing against AD: chasing #}
{# them costs round trips and reveals no extra data on a single-forest    #}
{# Samba domain.  Explicit is better than relying on provider defaults.   #}
ldap_referrals = false
{# Disable DDNS for determinism: SSSD's GSS-TSIG updates do reach the     #}
{# DC's AD-integrated zone (this works regardless of the site DNS being   #}
{# unmodifiable), but any A/PTR our stack actually relies on -- the DC's  #}
{# own PTR, the NFS server's A/PTR for rpc.gssd reverse resolution -- is  #}
{# registered explicitly during provisioning.  Leaving DDNS on adds       #}
{# nothing here and just produces background traffic and journald noise.  #}
dyndns_update = false
{% if sssd_access_provider == 'ad' %}
{# permissive mode: log GPO denials but don't enforce them, avoiding #}
{# lockouts from misconfigured or absent GPOs in a Samba AD domain #}
ad_gpo_access_control = permissive
{% if sssd_ad_access_filter %}
ad_access_filter = {{ sssd_ad_access_filter }}
{% elif sssd_login_anchor_group %}
{% set _base_dn = sssd_login_anchor_base_dn or ('CN=Users,DC=' + sssd_domain.replace('.', ',DC=')) %}
{# Chain-matching (OID 1.2.840.113556.1.4.1941) honours nested group #}
{# membership, so class groups nested inside the anchor on the DC   #}
{# grant access without re-rendering this file.                     #}
{# The DOM:<domain>: prefix is required.  SSSD's ad_access_filter   #}
{# parser splits on colons looking for keyword prefixes; without    #}
{# DOM: it misparses the colons in the extensible-match OID syntax  #}
{# and falls through to "deny all".  See ad_access.c parse_filter.  #}
ad_access_filter = DOM:{{ sssd_domain }}:(memberOf:1.2.840.113556.1.4.1941:=CN={{ sssd_login_anchor_group }},{{ _base_dn }})
{% endif %}
{% endif %}
{% if sssd_enable_autofs | bool %}
{# autofs maps stored in AD under OU=automount (nisMap/nisObject).  With #}
{# id_provider = ad SSSD uses the NIS attribute mapping by default, which #}
{# matches Samba AD's stock schema -- no ldap_autofs_* overrides needed. #}
autofs_provider = ad
{% endif %}
{% if sssd_enable_sudo | bool %}
{# AD-stored sudo rules are sudoRole objects in OU=SUDOers, written by     #}
{# bin/samba-sudorule.sh.  Pin the search base there explicitly: with no   #}
{# base SSSD auto-discovers one, and on a real Samba DC that produced a    #}
{# sudo full refresh that downloaded 0 rules -- so AD sudo rules silently  #}
{# never reached clients (`sudo -l` was always empty) even though the      #}
{# rules, membership, and host filter were all correct.                    #}
sudo_provider = ad
ldap_sudo_search_base = OU=SUDOers,DC={{ sssd_domain.replace('.', ',DC=') }}
{% endif %}
{% if sssd_enable_ssh | bool %}
{# SSH key retrieval from AD altSecurityIdentities attribute.  Keys are #}
{# stored as raw OpenSSH-format values (no prefix): SSSD's ssh responder #}
{# does not strip arbitrary prefixes, so anything other than a valid    #}
{# OpenSSH key would be passed through to sshd verbatim and rejected.   #}
ldap_user_ssh_public_key = altSecurityIdentities
ldap_user_extra_attrs = altSecurityIdentities
{% endif %}
