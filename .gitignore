# Test harness artefacts generated by test/setup.sh -- contain the random
# admin password and per-run inventory/group_vars.  Never commit.
test/test-config.env
test/inventory.yml
test/group_vars/
test/.ssh/

# Local Ansible Galaxy collection install path created by
# `ansible-galaxy collection install -r requirements.yml -p ansible/.ansible/collections`.
# Required so ansible-lint can resolve `microsoft.ad` / `ansible.windows`
# modules during local linting; not source code.
ansible/.ansible/
